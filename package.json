{
  "name": "mecm-log-viewer",
  "displayName": "MECM Log Viewer",
  "description": "Parse and display MECM/SCCM log files in an interactive AG Grid table.",
  "version": "1.0.0",
  "publisher": "your-publisher-id",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "MECM",
    "SCCM",
    "log",
    "viewer",
    "ConfigMgr"
  ],
  "activationEvents": [
    "onCommand:mecmLogViewer.openFile",
    "onLanguage:log"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mecmLogViewer.openFile",
        "title": "Open in MECM Log Viewer"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "when": "resourceExtname == .log",
          "command": "mecmLogViewer.openFile",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "when": "resourceExtname == .log",
          "command": "mecmLogViewer.openFile",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "mecmLogViewer.openFile",
          "when": "true"
        }
      ]
    },
    "languages": [
      {
        "id": "log",
        "extensions": [
          ".log"
        ]
      }
    ],
    "configuration": {
      "title": "MECM Log Viewer",
      "properties": {
        "mecmLogViewer.maxEntries": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Maximum number of log entries to load per file. 0 = no limit. Entries beyond the limit are discarded from the end of the file."
        },
        "mecmLogViewer.defaultSeverityFilter": {
          "type": "string",
          "enum": [
            "all",
            "warnings+",
            "errors"
          ],
          "enumDescriptions": [
            "Show all entries",
            "Show warnings and errors only",
            "Show errors only"
          ],
          "default": "all",
          "description": "Severity filter applied automatically when a file is first opened."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && node esbuild.extension.mjs && node esbuild.webview.mjs",
    "watch": "npm-run-all -p watch:ext watch:web watch:tsc",
    "watch:ext": "node esbuild.extension.mjs --watch",
    "watch:web": "node esbuild.webview.mjs --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && node esbuild.extension.mjs --production && node esbuild.webview.mjs --production",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "20.x",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.96.0",
    "esbuild": "^0.24.2",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@vscode/webview-ui-toolkit": "^1.4.0",
    "ag-grid-community": "^33.0.2",
    "ag-grid-react": "^33.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
